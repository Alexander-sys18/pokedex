# Base URL of the PokéAPI. Override only if you mirror the API.
POKEAPI_BASE_URL=https://pokeapi.co/api/v2

# How long (in seconds) detail pages cache PokéAPI responses (ISR).
# Pokémon data is effectively immutable, so a long TTL is safe.
POKEAPI_REVALIDATE_SECONDS=86400

# --- Asistente IA (opcional) -------------------------------------------------
# Sin esta clave, el chat "Pregúntale a la Pokédex" simplemente no aparece.
# La clave vive SOLO en el servidor (nunca se expone al cliente).
ANTHROPIC_API_KEY=

# Modelo del chat. Por defecto Claude Sonnet 5 (sobra para este asistente);
# claude-haiku-4-5 para menor coste, claude-opus-4-8 para máxima calidad.
CHAT_MODEL=claude-sonnet-5
